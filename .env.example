# KIE.AI API
KIE_AI_API_KEY=your_kie_ai_api_key_here
KIE_AI_API_URL=https://api.kie.ai/claude/v1

# Параметры прокси-сервера
PROXY_HOST=127.0.0.1
PROXY_PORT=11777

# Логирование
LOG_LEVEL=INFO
LOG_DIR=./logs
REQUEST_LOGGING_ENABLED=true
REQUEST_LOG_HEADERS=true
REQUEST_LOG_BODY=true
REQUEST_LOG_BODY_LIMIT=4096

# Модели
DEFAULT_MODEL=claude-opus-4-6
OLLAMA_COMPAT_VERSION=0.8.0
# Размер контекста, объявляемый клиентам в /api/show (VSCode Copilot читает это)
MODEL_CONTEXT_LENGTH=1000000
# Anthropic требует max_tokens -- дефолт для клиентов, что его не шлют
DEFAULT_MAX_TOKENS=8192
# Префикс перед именем модели для UI (VSCode/Copilot). Снимается перед запросом в KIE.AI
MODEL_NAME_PREFIX=kie/
